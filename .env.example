# GLIMMORA AEGIS Navy Backend — Environment Variables Example
# Copy this file to .env and fill in actual values

# Database
DATABASE_URL=postgresql://aegis:aegis_secret@localhost:5432/aegis_db

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama LLM (runs locally, air-gapped)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Qdrant Vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=aegis_admin
MINIO_SECRET_KEY=aegis_secret

# Application
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
